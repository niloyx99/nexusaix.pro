# OpenRouter (chart analysis)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Quotex market data API
QUOTEX_MARKET_API_URL=https://quotex-data-1n2b.onrender.com

# Server (Render sets PORT automatically)
PORT=7777
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aldi_bot?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=aldi_bot

# Admin panel password
ADMIN_PASSWORD=change_me

# This backend's public URL
BACKEND_URL=https://your-backend.onrender.com

# CORS — comma-separated client origins (frontend + admin + phone LAN)
CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:8889,http://localhost:8890,http://192.168.1.1:8889

# Frontend app URLs
FRONTEND_URL=https://your-frontend.onrender.com,http://localhost:8889,http://192.168.1.1:8889

# Admin panel URLs
ADMIN_URL=http://localhost:8890,http://192.168.1.1:8890
