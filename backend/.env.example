# OpenRouter (chart analysis)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Quotex market data API
QUOTEX_MARKET_API_URL=https://quotex-data-1n2b.onrender.com

# Server (Render sets PORT automatically)
PORT=7777
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aldi_bot?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=aldi_bot

# Admin panel password (used by /api/admin/licenses)
ADMIN_PASSWORD=change_me

# This API server's public URL (your Render backend URL)
BACKEND_URL=https://nexus-ai-backend.onrender.com

# CORS — comma-separated URLs of your SEPARATELY hosted apps
# Add every frontend + admin URL (Render, Vercel, local dev, phone LAN)
CORS_ORIGINS=https://your-frontend.onrender.com,https://your-admin.onrender.com,http://localhost:8889,http://localhost:8890,http://192.168.1.1:8889,http://192.168.1.1:8890

# Frontend app (hosted separately — NOT in this repo)
FRONTEND_URL=https://your-frontend.onrender.com,http://localhost:8889,http://192.168.1.1:8889

# Admin panel (hosted separately — NOT in this repo)
ADMIN_URL=https://your-admin.onrender.com,http://localhost:8890,http://192.168.1.1:8890
